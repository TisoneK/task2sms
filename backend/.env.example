# Application
APP_NAME=Task2SMS
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database (use SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./task2sms.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/task2sms

# Africa's Talking
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# GSM Modem
GSM_PORT=/dev/ttyUSB0
GSM_BAUDRATE=115200

# Default SMS provider: africastalking | twilio | gsm
DEFAULT_SMS_PROVIDER=africastalking

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Roles (admin | member)
DEFAULT_ROLE=member

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@task2sms.com
SMTP_FROM_NAME=Task2SMS

# WhatsApp (via Twilio WhatsApp sandbox or 360dialog)
WHATSAPP_PROVIDER=twilio
WHATSAPP_FROM=whatsapp:+14155238886

# Webhook signing secret (for outbound webhook HMAC)
WEBHOOK_SECRET=change-me-webhook-secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_PARSE_MODE=HTML
